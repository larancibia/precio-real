{
  "name": "precio-real-api",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker + D1 backend for precio-real (price tracker for MercadoLibre Argentina)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute precio-real --file=src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute precio-real --local --file=src/db/schema.sql",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:apply": "wrangler d1 execute precio-real --file=scripts/seed.sql",
    "db:seed:apply:local": "wrangler d1 execute precio-real --local --file=scripts/seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
