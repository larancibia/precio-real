[Unit]
Description=Precio Real FastAPI ingestion runtime
Requires=docker.service precio-real-postgres.service
After=docker.service network-online.target precio-real-postgres.service

[Service]
Type=oneshot
WorkingDirectory=/opt/precio-real-api
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose up -d api
ExecStop=/usr/bin/docker compose stop api
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
