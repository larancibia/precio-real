# Copy to .env on the server. Use real values only in the untracked .env file.
POSTGRES_DB=precio_real
POSTGRES_USER=precio_real_app
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://precio_real_app:replace-with-a-long-random-password@postgres:5432/precio_real

# Current production bind contract.
API_HOST=127.0.0.1
API_PORT=8402

# Current production external Postgres port for administration from localhost/VPS tooling.
POSTGRES_PUBLISHED_PORT=54330
