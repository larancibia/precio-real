    "https://*.changomas.com.ar/*",
    "https://*.electrolux.com.ar/*",
    "https://*.drean.com.ar/*",
    "https://*.motorola.com.ar/*",
    "https://*.todomodo.com.ar/*",
    "https://*.amazon.com.ar/*",
    "https://*.hipertehno.com.ar/*",
    "https://tienda.mi.com/ar/*",
    "https://*.philco.com.ar/*",
    "https://*.venex.com.ar/*",
    "https://*.bgood.com.ar/*",
    "https://*.hptienda.com.ar/*",
    "https://www.lenovo.com/ar/*",
    "https://*.alphatec.com.ar/*",
    "https://*.exo.com.ar/*",
    "http://localhost:8787/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Precio Real"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadolibre.com.ar/*",
        "https://*.fravega.com/*",
        "https://*.garbarino.com/*",
        "https://*.falabella.com.ar/*",
        "https://*.carrefour.com.ar/*",
        "https://*.cotodigital3.com.ar/*",
        "https://*.coto.com.ar/*",
        "https://*.naldo.com.ar/*",
        "https://*.musimundo.com/*",
        "https://*.cetrogar.com.ar/*",
        "https://*.megatone.net/*",
        "https://diaonline.supermercadosdia.com.ar/*",
        "https://*.jumbo.com.ar/*",
        "https://*.disco.com.ar/*",
        "https://*.sodimac.com.ar/*",
        "https://*.easy.com.ar/*",
        "https://*.hendel.com.ar/*",
        "https://*.rodo.com.ar/*",
        "https://*.ribeiro.com.ar/*",
        "https://*.compumundo.com.ar/*",
        "https://*.samsung.com.ar/*",
        "https://www.lg.com/ar/*",
        "https://*.sony.com.ar/*",
        "https://*.philips.com.ar/*",
        "https://*.bgh.com.ar/*",
        "https://*.noblex.com.ar/*",
        "https://*.whirlpool.com.ar/*",
        "https://*.changomas.com.ar/*",
        "https://*.electrolux.com.ar/*",
        "https://*.drean.com.ar/*",
        "https://*.motorola.com.ar/*",
        "https://*.todomodo.com.ar/*",
        "https://*.amazon.com.ar/*",
        "https://*.hipertehno.com.ar/*",
        "https://tienda.mi.com/ar/*",
        "https://*.philco.com.ar/*",
        "https://*.venex.com.ar/*",
        "https://*.bgood.com.ar/*",
        "https://*.hptienda.com.ar/*",
        "https://www.lenovo.com/ar/*",
        "https://*.alphatec.com.ar/*",
        "https://*.exo.com.ar/*"
      ],
      "js": ["config.js", "utils/retailers.js", "utils/helpers.js", "utils/affiliates.js", "content/content.js"],
      "css": ["content/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
